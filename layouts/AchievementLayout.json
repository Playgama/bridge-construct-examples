						"tag": "div",
						"content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"Exported from Figma, Optimized\">\n  <title>Optimized Figma Design - Achievements</title>\n  \n  <style>\n    <style>\n    /* Font Loading Optimized */\n    @font-face {\n      font-family: 'Geist Mono';\n      src: url('fonts/GeistMono-Regular.ttf') format('truetype');\n      font-weight: normal;\n      font-style: normal;\n      font-display: swap;\n    }\n\n    :root {\n      /* Typography */\n      --font-mono: 'Geist Mono', ui-monospace, monospace;\n      --font-sans: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n      \n      /* Colors */\n      --bg-main: #0d0d0f;\n      --bg-header: rgba(13, 13, 15, 0.92);\n      --bg-card: #29292e;\n      --bg-input: #1d1d21;\n      --bg-btn-primary: #9d50ff;\n      --bg-btn-secondary: #49494c;\n      --bg-back-icon: #2a2a2e;\n      --bg-back-hover: #38383e;\n      \n      /* Text */\n      --text-white: rgba(255, 255, 255, 0.8);\n      --text-accent: #d8bbff;\n      --text-muted: #8e8e93;\n    }\n\n    /* CSS Reset */\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    /* FIX: Force entire window to be dark to eliminate white bands */\n    html, body {\n      width: 100%;\n      min-height: 100vh;\n      background-color: var(--bg-main) !important;\n      overflow-x: hidden;\n    }\n\n    /* FIX: Master wrapper to handle Construct 3 full screen centering */\n    .app-wrapper {\n      width: 100%;\n      min-height: 100vh;\n      background-color: var(--bg-main);\n      padding: 20px; \n      color: #fff;\n      overflow-y: auto;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n\n    .page-container {\n      width: 100%;\n      max-width: 680px;\n      min-height: 100vh;\n      padding: 20px 0; \n      display: flex;\n      flex-direction: column;\n      margin: 0 auto;\n    }\n\n    @media (max-width: 1440px) { .page-container { padding: 16px 24px; } }\n    @media (max-width: 768px)  { .page-container { padding: 16px; } }\n\n    /* Typography Utilities */\n    .text-white { color: var(--text-white); }\n    .text-accent { color: var(--text-accent); }\n\n    /* --- Clean Back Button CSS --- */\n    .app-header {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 12px 8px;\n      width: 100%;\n      background-color: var(--bg-header);\n    }\n\n    .nav-back-btn {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n      background: none;\n      border: none;\n      cursor: pointer;\n    }\n\n    .back-icon-container {\n      background-color: var(--bg-back-icon);\n      width: 46px; \n      height: 46px;\n      border-radius: 50%;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      color: var(--text-muted);\n      transition: background-color 0.2s;\n    }\n\n    .nav-back-btn:hover .back-icon-container {\n      background-color: var(--bg-back-hover);\n    }\n\n    .back-label {\n      color: var(--text-muted);\n      font-family: var(--font-sans);\n      font-size: 20px; \n      font-weight: 500;\n    }\n\n    /* --- Cards --- */\n    .card-list {\n      display: flex;\n      flex-direction: column;\n      gap: 4px;\n      padding: 0 8px;\n      width: 100%;\n    }\n\n    .content-card {\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n      padding: 12px;\n      background-color: var(--bg-card);\n      border-radius: 12px;\n      min-height: 80vh;\n    }\n\n    .card-header {\n      padding: 8px 0;\n    }\n\n    .card-title {\n      font-family: var(--font-mono);\n      font-weight: 500;\n      font-size: 18px;\n      color: var(--text-white);\n    }\n\n    .card-body {\n      display: flex;\n      flex-direction: column;\n      gap: 16px;\n      padding-bottom: 16px;\n      border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n    }\n\n    .card-body:last-child {\n      border-bottom: none;\n      padding-bottom: 0;\n    }\n\n    .status-list {\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n      padding: 8px 0;\n    }\n\n    .status-item {\n      font-family: var(--font-mono);\n      font-size: 13px;\n    }\n\n    /* --- Form Inputs --- */\n    .form-row {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      width: 100%;\n    }\n\n    .input-wrapper {\n      display: flex;\n      align-items: center;\n      flex: 1;\n      background-color: var(--bg-input);\n      border-radius: 8px;\n    }\n\n    input.text-input {\n      width: 100%;\n      background: transparent;\n      border: none;\n      outline: none;\n      padding: 12px;\n      font-family: var(--font-mono);\n      font-size: 13px;\n      color: var(--text-white);\n    }\n\n    input.text-input::placeholder {\n      color: var(--text-white);\n      opacity: 0.7;\n    }\n\n    input.text-input:focus {\n      outline: 1px solid var(--text-accent);\n    }\n\n    /* --- Buttons --- */\n    .action-group {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      flex-wrap: wrap;\n    }\n\n    .btn {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      padding: 9px 12px;\n      border: none;\n      border-radius: 20px;\n      cursor: pointer;\n      transition: filter 0.2s ease;\n    }\n\n    .btn:hover {\n      filter: brightness(1.1);\n    }\n\n    .primary-btn {\n      background-color: var(--bg-btn-primary);\n    }\n\n    .secondary-btn {\n      background-color: var(--bg-btn-secondary);\n    }\n\n    .btn-label {\n      font-family: var(--font-mono);\n      font-size: 13px;\n      color: #fff;\n    }\n  </style>\n</head>\n<body class=\"app-wrapper\">\n  <div class=\"page-container\">\n    \n    <header class=\"app-header\">\n      <button class=\"nav-back-btn\" aria-label=\"Go Back\" id=\"back-btn\">\n        <div class=\"back-icon-container\" aria-hidden=\"true\">\n          <svg width=\"23\" height=\"23\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <polyline points=\"15 18 9 12 15 6\"></polyline>\n          </svg>\n        </div>\n        <span class=\"back-label\">Back</span>\n      </button>\n    </header>\n    \n    <main class=\"card-list\">\n      <section class=\"content-card\">\n        \n        <header class=\"card-header\">\n          <h2 class=\"card-title\">Achievements</h2>\n        </header>\n        \n        <div class=\"card-body\">\n          <div class=\"status-list\">\n            <p class=\"status-item\"><span class=\"text-white\">Is Achievements Supported: </span><span class=\"text-accent\" id=\"achivement-support-label\">false</span></p>\n            <p class=\"status-item\"><span class=\"text-white\">Is Get List Supported: </span><span class=\"text-accent\" id=\"get-list-support-label\">false</span></p>\n            <p class=\"status-item\"><span class=\"text-white\">Is Native Popup Supported: </span><span class=\"text-accent\" id=\"native-support-label\">false</span></p>\n          </div>\n        </div>\n\n        <div class=\"card-body\">\n          \n          <div class=\"form-row\">\n            <div class=\"input-wrapper\">\n              <input type=\"text\" class=\"text-input\" id=\"key-input\" placeholder=\"Key\" aria-label=\"Achievement Key\" />\n            </div>\n            <div class=\"input-wrapper\">\n              <input type=\"text\" class=\"text-input\" id=\"name-input\" placeholder=\"Name\" aria-label=\"Achievement Name\" />\n            </div>\n          </div>\n          \n          <div class=\"action-group\">\n            <button class=\"btn primary-btn\" id=\"unlock-btn\">\n              <span class=\"btn-label\">Unlock</span>\n            </button>\n            <button class=\"btn primary-btn\" id=\"get-list-btn\">\n              <span class=\"btn-label\">Get List</span>\n            </button>\n            <button class=\"btn primary-btn\" id=\"show-native-popup-btn\">\n              <span class=\"btn-label\">Show Native Popup</span>\n            </button>\n          </div>\n          \n        </div>\n\n      </section>\n    </main>\n    \n  </div>\n</body>\n</html>",
